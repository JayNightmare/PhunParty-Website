# API Configuration
VITE_API_URL=your_api_url_here

# WebSocket Configuration
VITE_WS_URL=wss://your_websocket_url_here

# Development Settings (for development proxy)
# In development, you can use localhost:8000 if running backend locally
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000

# Important Notes:
# 1. Do not put secrets in Vite env vars; browser bundles can expose them.
# 2. The frontend sends the logged-in user's JWT for authenticated API/WebSocket calls.
# 3. In production, make sure the server supports WebSocket connections.
